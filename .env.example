# Environment Variables for Sickle Care Connect
# Copy this file to .env and fill in your actual values
# IMPORTANT: DATABASE_URL is REQUIRED - the app will not run without it

# ===============================
# DATABASE CONFIGURATION (REQUIRED)
# ===============================
# For PostgreSQL on Render:
# DATABASE_URL=postgresql://username:password@host.render.com:5432/dbname
# For local PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/sicklecare

DATABASE_URL=postgresql://user:password@localhost:5432/sicklecare

# ===============================
# JWT SECURITY
# ===============================
# Use a strong random string (at least 32 characters)
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-random-key-at-least-32-characters-change-this-in-production

# ===============================
# ADMIN CREDENTIALS (Initial Setup)
# ===============================
# These are used to auto-create an admin account on first run
# If you don't set these, you'll need to create an admin manually
ADMIN_EMAIL=boss@sicklecare.com
ADMIN_PASSWORD=SecureAdminPassword123!
ADMIN_NAME=Sickle Care Administrator

# ===============================
# FLASK CONFIGURATION
# ===============================
FLASK_ENV=development
# Set to 'production' for deployment