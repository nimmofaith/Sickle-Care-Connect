# Environment Variables for Sickle Care Connect
# Copy this file to .env and fill in your actual values

# Admin Credentials (for initial setup)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-secure-password-here
ADMIN_NAME=System Administrator

# Flask Environment
FLASK_ENV=development
# Set to 'production' to disable sample data creation

# Database (if using different database)
# SQLALCHEMY_DATABASE_URI=sqlite:///sicklecare.db

# Other security settings can be added here as needed